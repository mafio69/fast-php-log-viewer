{
    "name": "mafio69/log-viewer",
    "description": "Standalone log viewer for fast-php-logger. Drop-in single file or Composer package.",
    "version": "2.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mariusz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-ssh2": "*",
        "ext-pdo_sqlite": "*",
        "mafio69/fast-php-logger": ">=1.0.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Mariusz\\LogViewer\\Controller\\": "src/Controller/",
            "Mariusz\\LogViewer\\Service\\": "src/Service/",
            "Mariusz\\LogViewer\\Repository\\": "src/Repository/",
            "Mariusz\\LogViewer\\Config\\": "src/Config/",
            "Mariusz\\LogViewer\\Middleware\\": "src/Middleware/",
            "Mariusz\\LogViewer\\Bootstrap\\": "src/Bootstrap/",
            "Mariusz\\LogViewer\\Routing\\": "src/Routing/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mariusz\\LogViewer\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "giorgiosironi/eris": "^1.1"
    },
    "scripts": {
        "build": "php bin/build.php",
        "test": "vendor/bin/phpunit"
    }
}
