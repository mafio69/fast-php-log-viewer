{
    "name": "mafio69/log-viewer",
    "description": "Standalone log viewer for fast-php-logger. Drop-in single file or Composer package.",
    "version": "2.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mariusz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-ssh2": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "Mariusz\\LogViewer\\Controller\\": "src/Controller/",
            "Mariusz\\LogViewer\\Service\\": "src/Service/",
            "Mariusz\\LogViewer\\Repository\\": "src/Repository/",
            "Mariusz\\LogViewer\\Config\\": "src/Config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mariusz\\LogViewer\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2"
    },
    "scripts": {
        "build": "php bin/build.php",
        "test": "vendor/bin/phpunit"
    }
}
