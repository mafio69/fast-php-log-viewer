{
    "name": "mafio69/fast-php-log-viewer",
    "description": "Standalone log viewer for fast-php-logger. Drop-in single file or Composer package.",
    "version": "1.0.2",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mariusz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Mariusz\\LogViewer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mariusz\\LogViewer\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "build": "php bin/build.php",
        "test": "vendor/bin/phpunit"
    }
}
