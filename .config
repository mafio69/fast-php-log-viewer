# fast-php-log-viewer configuration file
# This file contains non-sensitive environment variables for development and production.
# This file SHOULD be tracked by Git.

# APP_ENV: Define the environment the application is running in.
# Allowed values:
# - local: (Current) Local development environment with full debugging enabled.
# - dev: Development/Staging environment for testing before deployment.
# - tests: Dedicated environment for automated test suites (CI/CD).
# - prod: Production environment with maximum performance and security (minimal logs).
# For AI: Use this to determine if debugging tools and verbose logging should be active.
APP_ENV=local

# LOG_DIR: Path to the log directory relative to the project root.
# For developers: This is used in docker-compose.yml for volume mapping (mapped to /var/www/html/logs).
# For AI: This is the primary target directory for LogScanner and LogFinder services.
LOG_DIR=/logs

# EDITOR_URL: Template for opening files in your IDE from the log viewer.
# For developers: Customize this to match your IDE (e.g., phpstorm://, vscode://).
# For AI: Use this to generate clickable links in the UI for log entries with location data.
EDITOR_URL=phpstorm://open?file={file}&line={line}
